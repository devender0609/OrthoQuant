# SpineMetrics — Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to git

# Your Anthropic API key (for local dev only)
# In Vercel production, set ANTHROPIC_API_KEY in the Vercel dashboard instead
VITE_ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the API endpoint (defaults to /api/analyze in production)
# VITE_API_URL=https://api.anthropic.com/v1/messages
